[alias]
  aa = add --all
  ap = add --patch
  ci = commit -v
  co = checkout
  contributors = shortlog -s -n
  l = log --all --decorate --oneline --graph --pretty=colored
  pf = push --force-with-lease
  st = status
  submodule-update = submodule update --remote --merge

[branch]
  sort = -committerdate

[color]
  ui = auto

[column]
  ui = auto

[commit]
  verbose = true

[core]
  autocrlf = input
  excludesfile = ~/.gitignore
  fsmonitor = true
  pager = hunk pager
  untrackedCache = true

[delta]
  features = side-by-side line-numbers decorations
  line-numbers = true
  navigate = true
  side-by-side = true

[diff]
  algorithm = histogram
  colorMoved = plain
  mnemonicPrefix = true

[fetch]
  prune = true

[filter "lfs"]
  clean = git-lfs clean -- %f
  process = git-lfs filter-process
  required = true
  smudge = git-lfs smudge -- %f

[init]
  defaultBranch = main

[interactive]
  diffFilter = delta --color-only

[merge]
  conflictstyle = diff3
  ff = only

[pretty]
  colored = format:%Cred%h%Creset %s %Cgreen(%cr) %C(bold blue)%an%Creset

[pull]
  rebase = true

[push]
  autoSetupRemote = true
  default = current

[rebase]
  autosquash = true

[tag]
  sort = -version:refname

[user]
  name = Caio Bianchi
  email = caio@caio.ca
