[alias]
  aa = add --all
  ap = add --patch
  amend = commit --amend
  ci = commit -v
  cm = commit -m
  co = checkout
  contributors = shortlog -s -n
  l = log --all --decorate --oneline --graph --pretty=colored
  last = log -1 HEAD --stat
  pf = push --force-with-lease
  rb = rebase
  rbi = rebase --interactive
  rs = restore --staged
  st = status
  submodule-update = submodule update --remote --merge
  sw = switch
  swc = switch --create
  unstage = restore --staged

[branch]
  sort = -committerdate

[color]
  ui = auto

[column]
  ui = auto

[commit]
  verbose = true

[core]
  autocrlf = input
  editor = nvim
  excludesfile = ~/.gitignore
  fsmonitor = true
  ; pager = delta
  pager = hunk pager
  safecrlf = warn
  untrackedCache = true

[delta]
  navigate = true
  side-by-side = true
  line-numbers = true

[diff]
  algorithm = histogram
  colorMoved = plain
  mnemonicPrefix = true

[fetch]
  prune = true
  pruneTags = true

[filter "lfs"]
  clean = git-lfs clean -- %f
  process = git-lfs filter-process
  required = true
  smudge = git-lfs smudge -- %f

[init]
  defaultBranch = main

[interactive]
  diffFilter = delta --color-only

[merge]
  conflictstyle = zdiff3
  ff = only

[pretty]
  colored = format:%Cred%h%Creset %s %Cgreen(%cr) %C(bold blue)%an%Creset

[pull]
  rebase = true

[push]
  autoSetupRemote = true
  default = current

[rebase]
  autosquash = true

[rerere]
  enabled = true

[tag]
  sort = -version:refname

[user]
  name = Caio Bianchi
  email = caio@caio.ca
