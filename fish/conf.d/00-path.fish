# ================================================================
# PATH Management
# ================================================================

# Personal & project bins first
fish_add_path ~/bin
fish_add_path ~/.bin

# Homebrew & system
fish_add_path /opt/homebrew/bin
fish_add_path /opt/homebrew/sbin
fish_add_path /usr/local/sbin

# Other tools
fish_add_path /Applications/Ghostty.app/Contents/MacOS
