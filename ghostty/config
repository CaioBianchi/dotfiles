theme = dark:TokyoNight Storm,light:TokyoNight Day
font-family = "Lilex"
font-size = 15
window-width = 185
window-height = 50
window-padding-x = 8
window-padding-y = 6
auto-update-channel = stable
shell-integration-features = cursor,path,ssh-env,ssh-terminfo,sudo,title
link-previews = true
keybind = super+,=text:\x1bqghostty +edit-config\x0d
custom-shader = shaders/cursor_warp.glsl
background-opacity = 0.8
background-blur = macos-glass-regular
